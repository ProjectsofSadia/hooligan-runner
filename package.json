{
  "name": "hooligan-run",
  "displayName": "hooligan-run",
  "description": "Plays Hooligan by BTS on successful code runs",
  "version": "0.0.1",
  "publisher": "SadiaBuilds",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hooligan-run.play",
        "title": "Play Hooligan 🎵"
      }
    ],
    "keybindings": [
      {
        "command": "hooligan-run.play",
        "key": "ctrl+shift+h"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.110.0",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}